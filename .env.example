# Copy to .env for local overrides. Ports follow the backend convention
# (3333/3334; 3000 is reserved for a frontend).

AUTH_PORT=3333
RESOURCE_PORT=3334

# Postgres superuser (docker-compose). The init script creates two isolated
# databases — auth + app — each with its own user (ADR-0003).
POSTGRES_USER=hybrid
POSTGRES_PASSWORD=hybrid

# JWKS signing-key encryption (auth-service, F2). A base64-encoded 32-byte AES-256 key that seals
# signing-key private material at rest (AES-256-GCM). Generate with `openssl rand -base64 32`.
# NEVER commit a real value — `.env` is git-ignored; this example stays empty on purpose.
AUTH_JWKS_ENC_KEY=

# Per-service connection (used once the services talk to infra — later features):
#   auth-service     → auth DB   (user auth_user / pass auth)
#   resource-service → app DB    (user app_user  / pass app)
# AUTH_DATABASE_URL=jdbc:postgresql://localhost:5432/auth
# APP_DATABASE_URL=jdbc:postgresql://localhost:5432/app
# REDIS_URL=redis://localhost:6379
