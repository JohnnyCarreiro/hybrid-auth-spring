# Copy to .env for local overrides. Ports follow the backend convention
# (3333/3334; 3000 is reserved for a frontend).

AUTH_PORT=3333
RESOURCE_PORT=3334

# Postgres (docker-compose)
POSTGRES_USER=hybrid
POSTGRES_PASSWORD=hybrid
POSTGRES_DB=hybrid

# Connection strings (used once the services talk to infra — later features)
# DATABASE_URL=jdbc:postgresql://localhost:5432/hybrid
# REDIS_URL=redis://localhost:6379
