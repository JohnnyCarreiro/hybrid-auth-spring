# --- Obsidian (per-user state — never commit) ---
docs/**/.obsidian/workspace*.json
# Vendored theme is heavy and not load-bearing for the vault; plugins stay (the docs use them).
docs/**/.obsidian/themes/

# --- Java / Gradle ---
.gradle/
build/
**/build/
!gradle/wrapper/gradle-wrapper.jar

# --- Env / secrets ---
.env
*.env
!.env.example

# --- Keys (RS256 dev keys must never be committed) ---
*.pem
*.key
!**/*.example.pem

# --- IDE / OS ---
.idea/
*.iml
.vscode/
.DS_Store

# --- Local tooling (project-local binaries) ---
.tools/
